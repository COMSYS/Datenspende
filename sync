#!/bin/bash

# Define paths
CORE_DIR="$HOME/dev/powercollect-homeassistant/homeassistant/components/powercollect"
HACS_DIR="$HOME/dev/powercollect-hacs/custom_components/powercollect"
REPO_DIR="$HOME/dev/powercollect-hacs"

echo "Starting sync to HACS repository..."

# 1. Copy the integration files, explicitly excluding python cache and tests
rsync -av --exclude '__pycache__' --exclude 'tests' "$CORE_DIR/" "$HACS_DIR/"

echo "Files synced successfully."

# 2. Navigate to the HACS repo and handle Git operations
cd "$REPO_DIR" || exit

git add .
git status

# Prompt for a commit message
read -p "Enter commit message for HACS release: " commit_msg

git commit -m "$commit_msg"
git push origin main

echo "Integration pushed to HACS repository!"